---
const currentPath = Astro.url.pathname;
const isDocsPage = currentPath !== '/' && currentPath !== '';
---

<div class="header">
  <div class="nav-left">
    <a href="/" class="nav-logo">
      <svg width="22" height="16" viewBox="0 0 40 30" fill="none">
        <rect x="1" y="1" width="38" height="28" rx="2" stroke="#F4F0E8" stroke-width="1.5"/>
        <path d="M1 4L20 17L39 4" stroke="#E8A838" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
      <div class="wordmark"><span class="lang">lang</span><span class="mail">mail</span></div>
    </a>
    <div class="nav-links">
      <a href="/introduction/" class:list={["nav-link", { active: isDocsPage }]}>Docs</a>
    </div>
  </div>
  <div class="nav-right">
    <a href="https://github.com/usemarbles/langmail" class="nav-github-icon" target="_blank" rel="noopener" aria-label="GitHub">
      <svg width="20" height="20" viewBox="0 0 15 15" fill="none">
        <path d="M7.5 1C3.91 1 1 3.91 1 7.5c0 2.87 1.86 5.3 4.44 6.16.32.06.44-.14.44-.31v-1.08c-1.8.39-2.18-.87-2.18-.87-.3-.75-.72-.95-.72-.95-.59-.4.04-.4.04-.4.65.05 1 .67 1 .67.58 1 1.52.71 1.89.54.06-.42.23-.71.41-.87-1.44-.16-2.95-.72-2.95-3.2 0-.71.25-1.28.67-1.74-.07-.16-.29-.82.06-1.71 0 0 .55-.18 1.8.67A6.3 6.3 0 017.5 4.8c.56 0 1.12.07 1.64.22 1.25-.85 1.8-.67 1.8-.67.35.89.13 1.55.06 1.71.42.46.67 1.03.67 1.74 0 2.49-1.52 3.04-2.96 3.2.23.2.44.59.44 1.2v1.77c0 .17.11.37.44.31A6.5 6.5 0 0014 7.5C14 3.91 11.09 1 7.5 1z" fill="currentColor"/>
      </svg>
    </a>
  </div>
</div>

<style>
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .nav-left {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 9px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .wordmark {
    font-family: 'Lora', serif;
    font-size: 18px;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .wordmark .lang { color: var(--sl-color-white); }
  .wordmark .mail { color: var(--sl-color-accent); }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2px;
  }

  .nav-link {
    font-family: 'Geist', sans-serif;
    font-size: 13px;
    font-weight: 300;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    padding: 6px 14px;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .nav-link:hover { color: var(--sl-color-white); }
  .nav-link.active { color: var(--sl-color-white); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .nav-github-icon {
    display: inline-flex;
    align-items: center;
    color: var(--sl-color-gray-3);
    text-decoration: none;
    padding: 4px;
    transition: color 0.15s;
  }
  .nav-github-icon:hover { color: var(--sl-color-white); }
</style>
